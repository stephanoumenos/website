---
const year = new Date().getFullYear();
---

<footer class="border-t border-stone-200 dark:border-stone-800 mt-16">
  <div
    class="max-w-3xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-stone-400 dark:text-stone-500"
  >
    <p>© {year} Stefano De Checchi</p>
    <div class="flex gap-5">
      <a
        href="https://github.com/stephanoumenos"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-stone-700 dark:hover:text-stone-200 transition-colors"
      >
        GitHub
      </a>
      <a href="/rss.xml" class="hover:text-stone-700 dark:hover:text-stone-200 transition-colors">
        RSS
      </a>
    </div>
  </div>
</footer>
