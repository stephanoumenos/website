---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group border-b border-stone-200 dark:border-stone-800 last:border-0">
  <a
    href={`/writing/${slug}`}
    class="block py-6 -mx-4 px-4 sm:-mx-6 sm:px-6 rounded-lg hover:bg-stone-100/60 dark:hover:bg-stone-900/40 transition-colors"
  >
    <div class="flex items-center gap-3 mb-2">
      <time
        class="text-xs text-stone-400 dark:text-stone-500 tabular-nums shrink-0"
        datetime={pubDate.toISOString()}
      >
        {formattedDate}
      </time>
      <div class="flex gap-1.5 flex-wrap">
        {
          tags.map((tag) => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-stone-100 dark:bg-stone-800 text-stone-500 dark:text-stone-400">
              {tag}
            </span>
          ))
        }
      </div>
    </div>
    <h2
      class="font-[Instrument_Serif,Georgia,serif] text-xl font-normal text-stone-900 dark:text-stone-100 group-hover:text-sage-700 dark:group-hover:text-sage-400 transition-colors mb-1.5"
    >
      {title}
    </h2>
    <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed">
      {description}
    </p>
  </a>
</article>
