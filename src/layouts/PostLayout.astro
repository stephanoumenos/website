---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, tags, headings = [] } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const tocHeadings = headings.filter(
  (h) => h.depth <= 3 && h.slug !== 'contents'
);
---

<BaseLayout title={`${title} — stephanoumenos`} description={description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 relative">
    <!-- Back -->
    <a
      href="/writing"
      class="inline-flex items-center gap-1.5 text-sm text-stone-400 hover:text-stone-700 dark:hover:text-stone-200 mb-10 transition-colors group"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="group-hover:-translate-x-0.5 transition-transform"
      >
        <path d="m15 18-6-6 6-6" />
      </svg>
      All writing
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex flex-wrap gap-1.5 mb-5">
        {
          tags.map((tag) => (
            <span class="text-xs px-2.5 py-0.5 rounded-full bg-sage-50 dark:bg-sage-950/40 text-sage-700 dark:text-sage-400 border border-sage-200 dark:border-sage-900">
              {tag}
            </span>
          ))
        }
      </div>
      <h1
        class="font-[Instrument_Serif,Georgia,serif] text-4xl sm:text-5xl font-normal text-stone-900 dark:text-stone-100 leading-tight mb-4"
      >
        {title}
      </h1>
      <p class="text-lg text-stone-500 dark:text-stone-400 leading-relaxed mb-5">
        {description}
      </p>
      <div class="flex flex-wrap items-center gap-2 text-sm text-stone-400 dark:text-stone-500">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {
          updatedDate && (
            <>
              <span>·</span>
              <span>Updated {fmt(updatedDate)}</span>
            </>
          )
        }
      </div>
    </header>

    <hr class="border-stone-200 dark:border-stone-800 mb-10" />

    <!-- Sidebar TOC (desktop only) -->
    {tocHeadings.length > 0 && (
      <nav
        id="sidebar-toc"
        class="hidden 2xl:block fixed top-24 left-8 w-52 text-[0.9rem]"
        aria-label="Table of contents"
      >
        <div class="text-sm font-semibold text-stone-400 dark:text-stone-500 uppercase tracking-wider mb-3">
          On this page
        </div>
        <ul class="flex flex-col gap-1.5">
          {tocHeadings.map((h) => (
            <li>
              <a
                href={`#${h.slug}`}
                data-toc-link={h.slug}
                class:list={[
                  "toc-link block hover:text-stone-700 dark:hover:text-stone-300 transition-colors leading-snug",
                  h.depth === 2 ? "text-stone-400 dark:text-stone-500" : "pl-3 text-[0.8rem] text-stone-400/70 dark:text-stone-500/70",
                ]}
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <!-- Post content -->
    <article
      class="prose prose-stone dark:prose-invert max-w-none
        prose-headings:font-normal
        prose-pre:bg-stone-900 dark:prose-pre:bg-stone-900
        prose-pre:border prose-pre:border-stone-800
        prose-img:rounded-lg"
    >
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .toc-link.active {
    color: var(--color-stone-900);
    font-weight: 600;
  }
  :global(.dark) .toc-link.active {
    color: var(--color-stone-100);
  }
</style>

<script>
  function initToc() {
    const nav = document.getElementById('sidebar-toc');
    if (!nav) return;

    // Intersection Observer for active heading
    const links = nav.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    const slugs = Array.from(links).map((l) => l.dataset.tocLink!);
    const headingEls = slugs
      .map((s) => document.getElementById(s))
      .filter(Boolean) as HTMLElement[];

    if (headingEls.length === 0) return;

    let activeSlug = slugs[0];

    function setActive(slug: string) {
      if (slug === activeSlug) return;
      activeSlug = slug;
      links.forEach((l) => {
        l.classList.toggle('active', l.dataset.tocLink === slug);
      });
    }

    // Highlight the heading closest to (but above) the scroll offset
    const OFFSET = 100; // slightly more than scroll-padding-top (5rem = 80px)

    function updateActive() {
      let current = slugs[0];
      for (let i = 0; i < headingEls.length; i++) {
        if (headingEls[i].getBoundingClientRect().top <= OFFSET) {
          current = slugs[i];
        } else {
          break;
        }
      }
      setActive(current);
    }

    updateActive();
    window.addEventListener('scroll', updateActive, { passive: true });
  }

  // Run on initial load and on Astro page transitions
  initToc();
  document.addEventListener('astro:page-load', initToc);
</script>
