---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — stephanoumenos">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-6xl font-bold text-stone-200 dark:text-stone-800 mb-6">404</p>
    <h1 class="text-2xl font-semibold text-stone-900 dark:text-stone-100 mb-4">
      Page not found
    </h1>
    <p class="text-stone-500 dark:text-stone-400 mb-8">
      This page doesn't exist (or was moved).
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:underline"
    >
      ← Go home
    </a>
  </div>
</BaseLayout>
