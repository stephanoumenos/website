---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — stephanoumenos" description="About this site.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <article
      class="prose prose-stone dark:prose-invert max-w-none
        prose-headings:font-semibold
        prose-a:text-sage-700 dark:prose-a:text-sage-400"
    >
      <h1>About</h1>
      <p>
        I'm a software engineer interested in public policy, food systems, and how
        data can clarify questions that are usually argued about with intuition alone.
      </p>
      <p>
        This site is where I write about things I've spent time understanding. The
        focus tends to be on the intersection of policy and evidence — particularly
        where the numbers tell a different story than the public narrative.
      </p>
      <p>No tracking, no ads, no comments.</p>
      <h2>Contact</h2>
      <p>
        Reach me at <a href="mailto:stefano@dechecchi.dev">stefano@dechecchi.dev</a> or find me on
        <a href="https://github.com/stephanoumenos" target="_blank" rel="noopener noreferrer">GitHub</a>.
      </p>
    </article>
  </div>
</BaseLayout>
